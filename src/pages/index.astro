---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, PROJECTS, SOCIALS } from '../consts';

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="en">
<head><BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} /></head>
<body>
	<Header />
	<main class="home">
		<section class="hero">
			<h1>Hey, I'm Mothi<span class="wave">👋</span></h1>
			<p class="hero-sub">Product Marketing Manager at <strong>Cashfree Payments</strong>. I write about product marketing, Indian fintech, and building a career you're proud of.</p>
			<div class="hero-links">
				<a href={SOCIALS.github} target="_blank" rel="noopener" class="social-link" aria-label="GitHub">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
				</a>
				<a href={SOCIALS.linkedin} target="_blank" rel="noopener" class="social-link" aria-label="LinkedIn">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
				</a>
				<a href={SOCIALS.twitter} target="_blank" rel="noopener" class="social-link" aria-label="Twitter">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
				</a>
			</div>
		</section>

		<section class="section">
			<div class="section-hdr"><h2 class="section-title">Recent writing</h2><a href="/blog" class="section-link">All posts &rarr;</a></div>
			<ul class="post-list">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`} class="post-row">
							<div class="post-row-left">
								<span class="post-row-title">{post.data.title}</span>
							</div>
							<span class="post-row-meta"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</section>

		<section class="section">
			<div class="section-hdr"><h2 class="section-title">Projects</h2><a href="/projects" class="section-link">View all &rarr;</a></div>
			<div class="project-grid">
				{PROJECTS.slice(0,3).map((p) => (
					<a href={p.url} target="_blank" rel="noopener" class="project-card">
						<h3>{p.name}</h3>
						<p>{p.description}</p>
						<div class="project-tags">{p.tags.map((t) => <span class="ptag">{t}</span>)}</div>
					</a>
				))}
			</div>
		</section>
	</main>
	<Footer />
<script>document.body.classList.add('loaded');</script>
</body>
</html>

<style>
	.home { max-width: var(--wide-width); margin: 0 auto; padding: 0 var(--page-padding); }
	.hero { padding: 3.5rem 0 2.5rem; border-bottom: 1px solid var(--border-light); margin-bottom: 2.5rem; }
	.hero h1 { font-size: 2.5rem; margin: 0 0 0.75rem; letter-spacing: -0.03em; }
	.wave { display: inline-block; animation: wave 2.5s infinite; transform-origin: 70% 70%; margin-left: 0.1em; }
	@keyframes wave { 0%,60%,100%{transform:rotate(0)} 10%,30%{transform:rotate(14deg)} 20%{transform:rotate(-8deg)} 40%{transform:rotate(-4deg)} 50%{transform:rotate(10deg)} }
	.hero-sub { font-size: 1.125rem; line-height: 1.7; color: var(--text-secondary); margin: 0 0 1.25rem; max-width: 540px; }
	.hero-sub strong { color: var(--text-primary); font-weight: 600; }
	.hero-links { display: flex; gap: 0.5rem; }
	.social-link { display:flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:8px; color:var(--text-tertiary); border:1px solid var(--border-light); text-decoration:none; transition:all var(--ease); }
	.social-link:hover { color:var(--text-primary); border-color:var(--border-medium); background:var(--bg-secondary); }

	.section { margin-bottom: 3rem; }
	.section-hdr { display:flex; align-items:baseline; justify-content:space-between; margin-bottom:1rem; }
	.section-title { font-size:0.75rem; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-tertiary); margin:0; }
	.section-link { font-size:0.8rem; font-weight:500; text-decoration:none; color:var(--accent); }
	.section-link:hover { text-decoration: underline; }

	.post-list { list-style:none; padding:0; margin:0; }
	.post-row { display:flex; justify-content:space-between; align-items:baseline; gap:1rem; padding:0.75rem 0.75rem; margin:0 -0.75rem; text-decoration:none; border-bottom:1px solid var(--border-light); border-radius:8px; transition:background var(--ease); }
	.post-list li:last-child .post-row { border-bottom:none; }
	.post-row:hover { background:var(--bg-secondary); }
	.post-row-left { display:flex; align-items:center; gap:0.75rem; min-width:0; }
	.post-row-title { font-size:0.95rem; font-weight:600; color:var(--text-primary); line-height:1.35; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
	.post-row-meta { font-size:0.8rem; color:var(--text-tertiary); white-space:nowrap; flex-shrink:0; }

	.project-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:1rem; }
	.project-card { padding:1.25rem; border:1px solid var(--border-light); border-radius:10px; text-decoration:none !important; color:inherit; background:var(--bg-card); transition:background 150ms ease-out,border-color 150ms ease-out,box-shadow 150ms ease-out; }
	.project-card:hover { background:var(--accent-light); border-color:var(--accent); box-shadow:0 0 0 1px var(--accent); }
	.project-card:hover h3 { color:var(--accent); }
	.project-card h3 { font-size:0.95rem; margin:0 0 0.35rem; color:var(--text-primary); transition:color 150ms ease-out; }
	.project-card p { font-size:0.8rem; color:var(--text-secondary); margin:0 0 0.75rem; line-height:1.5; }
	.project-tags { display:flex; gap:0.35rem; flex-wrap:wrap; }
	.ptag { font-size:0.65rem; padding:0.15em 0.5em; border-radius:100px; background:var(--bg-secondary); color:var(--text-tertiary); font-weight:500; }

	@media (max-width:640px) {
		.hero h1 { font-size:1.875rem; }
		.post-row { flex-direction:column; gap:0.2rem; }
	}
</style>
