---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, PROJECTS, SOCIALS } from '../consts';

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latest = posts.slice(0, 6);
---

<!doctype html>
<html lang="en">
<head><BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} /></head>
<body>
	<Header />
	<main class="home home-main">

		<!-- HERO ───────────────────────────────────────── -->
		<section class="hero">
			<p class="eyebrow">Writing, projects, notes</p>
			<h1 class="hero-title">
				Hi, I'm Mothi — product marketing leader at <a href="https://cashfree.com" class="accent-link">Cashfree Payments</a>, writing about Indian fintech, PMM craft, and building a career you're proud of.
			</h1>
			<p class="hero-sub">
				Previously at Qoruz. Built go-to-market from zero. I write here when I have something I'd want to read myself.
			</p>
		</section>

		<!-- LATEST WRITING ─────────────────────────────── -->
		<section class="section">
			<div class="section-hdr">
				<h2 class="section-title">Latest writing</h2>
				<a href="/blog" class="section-link">All posts →</a>
			</div>
			<div class="notes-grid">
				{latest.map((post) => (
					<a href={`/blog/${post.id}/`} class="note-card bounce-in">
						<div class="note-cats">
							{(post.data.categories || []).slice(0, 1).map((c: string) => (
								<span class="category-pill" data-category={c}>{c}</span>
							))}
						</div>
						<h3 class="note-title">{post.data.title}</h3>
						<p class="note-desc">{post.data.description}</p>
						<div class="note-meta">
							<FormattedDate date={post.data.pubDate} />
						</div>
					</a>
				))}
			</div>
		</section>

		<!-- PROJECTS ───────────────────────────────────── -->
		<section class="section">
			<div class="section-hdr">
				<h2 class="section-title">Projects</h2>
				<a href="/projects" class="section-link">View all →</a>
			</div>
			<div class="project-grid">
				{PROJECTS.map((p, i) => (
					<a href={p.url} target="_blank" rel="noopener" class="project-card bounce-in" style={`animation-delay: ${60 + i * 80}ms`}>
						<h3>{p.name}</h3>
						<p>{p.description}</p>
						<div class="project-tags">{p.tags.map((t) => <span class="ptag">{t}</span>)}</div>
					</a>
				))}
			</div>
		</section>

		<!-- CONTACT ────────────────────────────────────── -->
		<section class="contact">
			<h2 class="contact-title">Say hi</h2>
			<p class="contact-body">
				The best ways to reach me:
				<a href={SOCIALS.email}>email</a>,
				<a href={SOCIALS.twitter} target="_blank" rel="noopener">twitter</a>, or
				<a href={SOCIALS.linkedin} target="_blank" rel="noopener">linkedin</a>.
			</p>
		</section>

	</main>
	<Footer />
<script>document.body.classList.add('loaded');</script>
</body>
</html>

<style>
	.home {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--page-padding);
	}

	/* ── HERO ───────────────────────────────────────── */
	.hero {
		padding: 4.5rem 0 3.5rem;
		border-bottom: 1px solid var(--border-light);
		margin-bottom: 3.5rem;
	}
	.eyebrow {
		font-family: ui-sans-serif, system-ui, sans-serif;
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--text-tertiary);
		margin: 0 0 1.2rem;
	}
	.hero-title {
		font-family: 'PT Serif', Georgia, serif;
		font-size: clamp(1.75rem, 4.2vw, 2.85rem);
		font-weight: 700;
		line-height: 1.25;
		letter-spacing: -0.015em;
		color: var(--text-primary);
		margin: 0 0 1.5rem;
		max-width: 820px;
	}
	.accent-link {
		color: var(--accent);
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-underline-offset: 4px;
		text-decoration-color: var(--accent-glow);
	}
	.accent-link:hover { text-decoration-color: var(--accent); }
	.hero-sub {
		font-family: 'PT Serif', Georgia, serif;
		font-size: 1.125rem;
		line-height: 1.65;
		color: var(--text-secondary);
		font-style: italic;
		margin: 0;
		max-width: 640px;
	}

	/* ── SECTIONS ───────────────────────────────────── */
	.section { margin-bottom: 4rem; }
	.section-hdr {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 1.5rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--border-light);
	}
	.section-title {
		font-family: 'PT Serif', Georgia, serif;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--text-tertiary);
		margin: 0;
	}
	.section-link {
		font-family: ui-sans-serif, system-ui, sans-serif;
		font-size: 0.82rem;
		font-weight: 500;
		text-decoration: none;
		color: var(--text-secondary);
	}
	.section-link:hover { color: var(--accent); }

	/* ── NOTES GRID ─────────────────────────────────── */
	.notes-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.25rem;
	}
	.note-card {
		display: flex;
		flex-direction: column;
		padding: 1.5rem 1.5rem 1.25rem;
		background: var(--bg-card);
		border: 1px solid var(--border-light);
		border-radius: 12px;
		text-decoration: none;
		color: inherit;
		transition:
			transform var(--ease),
			border-color var(--ease),
			box-shadow var(--ease);
	}
	.note-card:hover {
		transform: translateY(-3px);
		border-color: var(--border-medium);
		box-shadow: var(--shadow-md);
	}
	.note-cats { margin-bottom: 0.8rem; min-height: 1.2rem; }
	.note-title {
		font-family: 'PT Serif', Georgia, serif;
		font-size: 1.1rem;
		font-weight: 700;
		line-height: 1.35;
		color: var(--text-primary);
		margin: 0 0 0.6rem;
	}
	.note-card:hover .note-title { color: var(--accent); }
	.note-desc {
		font-size: 0.92rem;
		line-height: 1.55;
		color: var(--text-secondary);
		margin: 0 0 1rem;
		flex-grow: 1;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.note-meta {
		font-family: ui-sans-serif, system-ui, sans-serif;
		font-size: 0.75rem;
		color: var(--text-tertiary);
	}

	/* ── PROJECTS ───────────────────────────────────── */
	.project-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
		gap: 1.25rem;
	}
	.project-card {
		padding: 1.5rem;
		border: 1px solid var(--border-light);
		border-radius: 12px;
		text-decoration: none !important;
		color: inherit;
		background: var(--bg-card);
		transition: transform var(--ease), border-color var(--ease), box-shadow var(--ease);
	}
	.project-card:hover {
		transform: translateY(-3px);
		border-color: var(--accent);
		box-shadow: var(--shadow-md);
	}
	.project-card h3 {
		font-family: 'PT Serif', Georgia, serif;
		font-size: 1.05rem;
		margin: 0 0 0.4rem;
		color: var(--text-primary);
		transition: color var(--ease);
	}
	.project-card:hover h3 { color: var(--accent); }
	.project-card p {
		font-size: 0.88rem;
		color: var(--text-secondary);
		margin: 0 0 0.9rem;
		line-height: 1.55;
	}
	.project-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
	.ptag {
		font-family: ui-sans-serif, system-ui, sans-serif;
		font-size: 0.68rem;
		padding: 0.2em 0.55em;
		border-radius: 100px;
		background: var(--bg-secondary);
		color: var(--text-tertiary);
		font-weight: 500;
	}

	/* ── CONTACT ────────────────────────────────────── */
	.contact {
		margin-top: 2rem;
		padding: 3rem 0 1rem;
		border-top: 1px solid var(--border-light);
	}
	.contact-title {
		font-family: 'PT Serif', Georgia, serif;
		font-size: 1.875rem;
		margin: 0 0 1rem;
	}
	.contact-body {
		font-size: 1.125rem;
		color: var(--text-secondary);
		margin: 0;
		font-style: italic;
	}
	.contact-body a { color: var(--accent); font-style: normal; }

	@media (max-width: 640px) {
		.hero { padding: 2.5rem 0 2rem; }
		.hero-title { font-size: 1.75rem; }
	}
</style>
