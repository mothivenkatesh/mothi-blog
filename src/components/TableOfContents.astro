---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth >= 2 && h.depth <= 3);
const show = filtered.length >= 3;
---

{show && (
	<!-- Mobile: collapsible -->
	<details class="toc-mobile">
		<summary>Table of contents</summary>
		<nav aria-label="Table of contents">
			<ol class="toc-list">
				{filtered.map(h => (
					<li class={`toc-depth-${h.depth}`}>
						<a href={`#${h.slug}`}>{h.text}</a>
					</li>
				))}
			</ol>
		</nav>
	</details>

	<!-- Desktop: sticky sidebar -->
	<aside class="toc-sidebar" aria-label="Table of contents">
		<p class="toc-title">Contents</p>
		<nav>
			<ol class="toc-list">
				{filtered.map(h => (
					<li class={`toc-depth-${h.depth}`}>
						<a href={`#${h.slug}`}>{h.text}</a>
					</li>
				))}
			</ol>
		</nav>
	</aside>
)}

<style>
	.toc-mobile {
		display: block;
		margin: 1.5em 0;
		background: var(--bg-secondary);
		border-radius: 8px;
		padding: 0;
	}
	.toc-mobile summary {
		padding: 0.75em 1em;
		font-weight: 600;
		font-size: 0.875rem;
		color: var(--text-secondary);
		cursor: pointer;
		list-style: none;
	}
	.toc-mobile summary::before {
		content: "+" ;
		margin-right: 0.5em;
		font-weight: 700;
	}
	.toc-mobile[open] summary::before {
		content: "−" ;
	}
	.toc-mobile nav {
		padding: 0 1em 1em 1em;
	}

	.toc-sidebar {
		display: none;
	}

	@media (min-width: 1200px) {
		.toc-mobile {
			display: none;
		}
		.toc-sidebar {
			display: block;
			position: fixed;
			right: max(1rem, calc((100vw - 720px) / 2 - 280px));
			top: 80px;
			width: 220px;
			max-height: calc(100vh - 120px);
			overflow-y: auto;
			padding: 0;
		}
	}

	.toc-title {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-tertiary);
		margin: 0 0 0.75em 0;
	}

	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.toc-list li {
		margin: 0;
	}
	.toc-list a {
		display: block;
		padding: 0.3em 0;
		font-size: 0.8rem;
		line-height: 1.4;
		color: var(--text-tertiary);
		text-decoration: none;
		border-left: 2px solid transparent;
		padding-left: 0.75em;
		transition: color 0.15s, border-color 0.15s;
	}
	.toc-list a:hover,
	.toc-list a.active {
		color: var(--text-primary);
		border-left-color: var(--accent);
	}
	.toc-depth-3 a {
		padding-left: 1.5em;
		font-size: 0.75rem;
	}
</style>

<script>
	const headingEls = document.querySelectorAll('article h2[id], article h3[id]');
	const tocLinks = document.querySelectorAll('.toc-list a');

	if (headingEls.length && tocLinks.length) {
		const observer = new IntersectionObserver(entries => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					tocLinks.forEach(a => a.classList.remove('active'));
					const id = entry.target.id;
					const link = document.querySelector(`.toc-sidebar .toc-list a[href="#${id}"]`);
					if (link) link.classList.add('active');
				}
			});
		}, { rootMargin: '-80px 0px -75% 0px' });

		headingEls.forEach(h => observer.observe(h));
	}
</script>
