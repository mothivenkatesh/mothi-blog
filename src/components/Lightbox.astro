---
// Lightbox: click any prose image to view full-size overlay
// No dependencies — pure CSS + vanilla JS
---

<div class="lightbox-overlay" id="lightbox" role="dialog" aria-modal="true" aria-label="Image preview" hidden>
  <button class="lightbox-close" id="lightbox-close" aria-label="Close image preview">&times;</button>
  <img class="lightbox-img" id="lightbox-img" src="" alt="" />
</div>

<style>
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: zoom-out;
    opacity: 0;
    transition: opacity 200ms ease-out;
    padding: 2rem;
  }
  .lightbox-overlay[hidden] {
    display: none;
  }
  .lightbox-overlay.visible {
    opacity: 1;
  }

  .lightbox-img {
    max-width: 95vw;
    max-height: 92vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
    transform: scale(0.95);
    transition: transform 200ms ease-out;
    cursor: default;
  }
  .lightbox-overlay.visible .lightbox-img {
    transform: scale(1);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    line-height: 1;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition: color 150ms, background 150ms;
  }
  .lightbox-close:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.2);
  }

  /* Make prose images show zoom cursor */
  :global(.prose img) {
    cursor: zoom-in;
  }
</style>

<script>
  const overlay = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close')!;

  function open(src: string, alt: string) {
    lbImg.src = src;
    lbImg.alt = alt;
    overlay.hidden = false;
    // Trigger reflow then animate in
    overlay.offsetHeight;
    overlay.classList.add('visible');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    overlay.classList.remove('visible');
    document.body.style.overflow = '';
    setTimeout(() => {
      overlay.hidden = true;
      lbImg.src = '';
    }, 200);
  }

  // Attach to all prose images (not avatars/icons)
  document.querySelectorAll('.prose img').forEach(img => {
    // Skip tiny images (avatars, icons)
    if (img.clientWidth < 100) return;

    img.addEventListener('click', (e) => {
      e.preventDefault();
      const target = e.currentTarget as HTMLImageElement;
      open(target.src, target.alt);
    });
  });

  // Close on overlay click (but not on image click)
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) close();
  });

  closeBtn.addEventListener('click', close);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay.hidden) close();
  });
</script>
