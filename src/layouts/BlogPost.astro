---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import SeriesNav from '../components/SeriesNav.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import Lightbox from '../components/Lightbox.astro';

interface Heading { depth: number; slug: string; text: string; }

interface Props {
	title: string; description: string; pubDate: Date; updatedDate?: Date;
	heroImage?: string; categories?: string[]; readTime?: number;
	headings?: Heading[]; currentPost?: CollectionEntry<'blog'>; allPosts?: CollectionEntry<'blog'>[];
}

const { title, description, pubDate, updatedDate, heroImage, categories = [], readTime, headings = [], currentPost, allPosts = [] } = Astro.props;
---

<html lang="en">
<head><BaseHead title={title} description={description} /></head>
<body>
	<div class="progress-bar" id="progress-bar" aria-hidden="true"></div>
	<Header />
	<main>
		<article>
			{heroImage && heroImage.length > 0 && (
				<div class="hero-image"><img src={heroImage} alt={title} width="920" height="460" loading="eager" decoding="async" fetchpriority="high" /></div>
			)}
			<div class="prose-wrapper">
				<div class="prose">
					<div class="title-block">
						<h1>{title}</h1>
						<div class="meta-row">
							<FormattedDate date={pubDate} />
							{readTime && <><span class="dot">&middot;</span><span>{readTime} min read</span></>}
						</div>
						{categories.length > 0 && (
							<div class="cats">{categories.map((c: string) => <span class="category-pill" data-category={c}>{c}</span>)}</div>
						)}
						{updatedDate && <p class="updated">Updated <FormattedDate date={updatedDate} /></p>}
					</div>

					{currentPost && allPosts.length > 0 && <SeriesNav currentPost={currentPost} allPosts={allPosts} />}
					<TableOfContents headings={headings} />

					<slot />

					{currentPost && allPosts.length > 0 && <SeriesNav currentPost={currentPost} allPosts={allPosts} />}

					<div class="share-bar">
						<button class="copy-link-btn" id="copy-link" aria-label="Copy link">
							<svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path d="M12.232 4.232a2.5 2.5 0 0 1 3.536 3.536l-1.225 1.224a.75.75 0 0 0 1.061 1.06l1.224-1.224a4 4 0 0 0-5.656-5.656l-3 3a4 4 0 0 0 .225 5.865.75.75 0 0 0 .977-1.138 2.5 2.5 0 0 1-.142-3.667l3-3Z"/><path d="M11.603 7.963a.75.75 0 0 0-.977 1.138 2.5 2.5 0 0 1 .142 3.667l-3 3a2.5 2.5 0 0 1-3.536-3.536l1.225-1.224a.75.75 0 0 0-1.061-1.06l-1.224 1.224a4 4 0 1 0 5.656 5.656l3-3a4 4 0 0 0-.225-5.865Z"/></svg>
							<span>Copy link</span>
						</button>
					</div>

					<div class="author-card">
						<img src="/images/blog/cropped-mothi.png" alt="Mothi" class="author-avatar" width="52" height="52" loading="lazy" decoding="async" />
						<div class="author-info">
							<strong>Mothi</strong>
							<p>PMM at Cashfree Payments. Writing about product marketing, fintech, and career growth.</p>
						</div>
					</div>

					{currentPost && allPosts.length > 0 && <RelatedPosts currentPost={currentPost} allPosts={allPosts} />}
				</div>
			</div>
		</article>
	</main>
	<Lightbox />
	<Footer />

	<script>
		// Mark body as loaded for CSS transitions (prevents flash on initial load)
		document.body.classList.add('loaded');

		// Progress bar — uses passive scroll, requestAnimationFrame for paint efficiency
		const bar = document.getElementById('progress-bar');
		const article = document.querySelector('article');
		if (bar && article) {
			let ticking = false;
			const update = () => {
				const r = article.getBoundingClientRect();
				const t = r.height - window.innerHeight;
				if (t > 0) bar.style.width = Math.min(100, Math.max(0, (-r.top / t) * 100)) + '%';
				ticking = false;
			};
			window.addEventListener('scroll', () => {
				if (!ticking) { requestAnimationFrame(update); ticking = true; }
			}, { passive: true });
			update();
		}

		// Copy link — clipboard API with execCommand fallback
		document.getElementById('copy-link')?.addEventListener('click', (e) => {
			const url = window.location.href;
			const span = (e.currentTarget as HTMLElement)?.querySelector('span');
			const done = () => {
				if (span) { const o = span.textContent; span.textContent = 'Copied!'; setTimeout(() => { span.textContent = o; }, 2000); }
			};
			if (navigator.clipboard?.writeText) {
				navigator.clipboard.writeText(url).then(done).catch(() => { fbCopy(url); done(); });
			} else { fbCopy(url); done(); }
		});
		function fbCopy(t: string) {
			const a = document.createElement('textarea');
			a.value = t; a.style.cssText = 'position:fixed;left:-9999px';
			document.body.appendChild(a); a.select(); document.execCommand('copy');
			document.body.removeChild(a);
		}
	</script>
</body>
</html>

<style>
	.progress-bar { position:fixed; top:0; left:0; height:3px; width:0%; background:var(--accent); z-index:1000; transition:width 50ms linear; }
	.hero-image { width:100%; max-width:920px; margin:0 auto 2em; padding:0 var(--page-padding); }
	.hero-image img { display:block; width:100%; height:auto; aspect-ratio:2/1; object-fit:cover; border-radius:12px; box-shadow:var(--shadow-md); }

	.prose-wrapper { position:relative; }
	.prose { width:var(--content-width); max-width:calc(100% - 2em); margin:auto; padding:1em; }

	.title-block { margin-bottom:2.5em; padding-bottom:1.5em; border-bottom:1px solid var(--border-light); }
	.title-block h1 { margin:0 0 0.75em; font-size:2.25rem; line-height:1.2; letter-spacing:-0.025em; font-family:'Inter',sans-serif; }
	.meta-row { display:flex; align-items:center; flex-wrap:wrap; gap:0.5em; color:var(--text-tertiary); font-size:0.85rem; font-family:'Inter',sans-serif; }
	.dot { color:var(--border-light); }
	.cats { display:flex; gap:0.4rem; flex-wrap:wrap; margin-top:0.75em; }
	.updated { font-style:italic; font-size:0.8rem; color:var(--text-tertiary); margin-top:0.5em; font-family:'Inter',sans-serif; }

	.share-bar { display:flex; justify-content:flex-end; margin-top:2em; }
	.copy-link-btn {
		display:inline-flex; align-items:center; gap:0.4em;
		padding:0.5em 0.9em; font-size:0.8rem; font-weight:500;
		color:var(--text-secondary); background:var(--bg-secondary);
		border:1px solid var(--border-light); border-radius:6px;
		cursor:pointer; transition:background var(--ease),color var(--ease); font-family:inherit;
	}
	.copy-link-btn:hover { background:var(--bg-card); color:var(--text-primary); }

	.author-card {
		display:flex; align-items:center; gap:1em;
		padding:1.25em; margin-top:3em;
		background:var(--bg-secondary); border-radius:12px;
	}
	.author-avatar { width:52px; height:52px; border-radius:50%; object-fit:cover; flex-shrink:0; }
	.author-info strong { display:block; font-size:0.9rem; color:var(--text-primary); margin-bottom:0.2em; font-family:'Inter',sans-serif; }
	.author-info p { margin:0; font-size:0.8rem; color:var(--text-secondary); line-height:1.5; font-family:'Inter',sans-serif; }

	@media (max-width:768px) { .title-block h1 { font-size:1.75rem; } }
</style>
